datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}
enum Role {
  USER
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
  ACCOUNTANT
  PATIENT
}
enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  BLOCKED
}
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}
enum PaymentMethod {
  CARD
  CASH
  UPI
}

// User Model
model user {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  avatar    String?
  role      Role?     @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    UserStatus @default(ACTIVE)

  patient   patient?
  doctor    doctor?
}

// Patient Model
model patient {
  id        String   @id @default(cuid())
  userId    String   @unique
  age       Int
  gender    Gender
  phone     String
  address   String?

  user      user     @relation(fields: [userId], references: [id])
  appointments appointment[]
  records   medical_record[]
  billing   billing[]
}

model doctor {
  id            String   @id @default(cuid())
  userId        String   @unique
  specialization String
  experience     Int
  phone         String

  user          user     @relation(fields: [userId], references: [id])
  appointments  appointment[]
  medicalrecord medical_record[]
}

model medical_record {
  id         String   @id @default(cuid())
  patientId  String
  doctorId   String?
  notes      String
  createdAt  DateTime @default(now())

  patient    patient  @relation(fields: [patientId], references: [id])
  doctor     doctor?  @relation(fields: [doctorId], references: [id])
}

model appointment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  date      DateTime
  status    AppointmentStatus

  patient   patient @relation(fields: [patientId], references: [id])
  doctor    doctor  @relation(fields: [doctorId], references: [id])
}

model billing {
  id        String   @id @default(cuid())
  patientId String
  amount    Float
  status    PaymentStatus
  method    PaymentMethod

  patient   patient @relation(fields: [patientId], references: [id])
}